# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── rclone ────────────────────────────────────────────────────────────────────
# Name of the rclone remote profile defined in ~/.config/rclone/rclone.conf
RCLONE_REMOTE=

# Bucket names (without the remote prefix)
DEV_BUCKET_NAME=
PROD_BUCKET_NAME=

# ── local paths ───────────────────────────────────────────────────────────────
# Scratch directory for temporary staging files
SCRATCH_DIR=/tmp/cloudtools
